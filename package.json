{
  "name": "momconnect",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:home": "turbo dev --filter=home",
    "dev:market": "turbo dev --filter=market",
    "dev:village": "turbo dev --filter=village",
    "dev:launch": "turbo dev --filter=launch",
    "dev:restore": "turbo dev --filter=restore",
    "dev:safe": "turbo dev --filter=safe",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "turbo": "^2.9.3"
  }
}
